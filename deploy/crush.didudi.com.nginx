# Crush — nginx server block. Install to /etc/nginx/sites-available/crush.didudi.com
# then symlink into sites-enabled, `nginx -t`, reload. certbot --nginx adds the 443
# block + the 80->443 redirect automatically.
server {
    listen 80;
    listen [::]:80;
    server_name crush.didudi.com;

    root /var/www/crush/public;
    index index.php;
    client_max_body_size 8m;

    # Front controller: route everything that isn't a real file to public/index.php
    location / {
        try_files $uri /index.php$is_args$args;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php8.4-fpm-crush.sock;
    }

    # Long-cache static assets
    location ^~ /assets/ {
        try_files $uri =404;
        expires 7d;
        access_log off;
    }

    # Never serve dotfiles (except ACME challenges)
    location ~ /\.(?!well-known) {
        deny all;
    }
}
